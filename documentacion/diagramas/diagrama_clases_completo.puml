' ================================================================
' PAQUETE RAÍZ
' ================================================================
package "simuladorminipc" #FFFDE7 {

    class MainFrame {
        +{static} main(args : String[]) : void
    }
}

' ================================================================
' PAQUETE FX — PRESENTACIÓN
' ================================================================
package "simuladorminipc.fx" #E8EAF6 {

    class SimuladorApp {
        -controller : SimuladorController
        -primaryStage : Stage
        --
        +start(stage : Stage) : void
        +{static} main(args : String[]) : void
        -buildToolbar() : Node
        -buildCpuPanel() : Node
        -buildQueueTables() : Node
        -buildMemoryPanel() : Node
        -buildEventLog() : Node
        -buildStatsPanel() : Node
    }

    class SimuladorController {
        -kernel : Kernel
        -autoTimeline : Timeline
        -newQueueRows : ObservableList<ProcessRow>
        -readyQueueRows : ObservableList<ProcessRow>
        -blockedQueueRows : ObservableList<ProcessRow>
        -terminatedQueueRows : ObservableList<ProcessRow>
        -memoryRows : ObservableList<MemoryRow>
        -diskRows : ObservableList<DiskRow>
        -eventLogItems : ObservableList<String>
        -currentTickProp : LongProperty
        -cpuStatusProp : StringProperty
        -cpuProcessProp : StringProperty
        -waitingForKeyboardProcess : PCB
        --
        +loadFiles() : void
        +step() : void
        +toggleAuto() : void
        +startSingleProcess() : void
        +reset() : void
        +provideKeyboardInput(value : int) : void
        +setPolicy(p : Policy) : void
        +setQuantum(q : int) : void
        -refreshUI() : void
        +onTickCompleted(tick : long) : void
        +onProcessStateChanged(p : PCB, prev : ProcessState, curr : ProcessState) : void
        +onScreenOutput(p : PCB, text : String) : void
        +onKeyboardInputRequired(p : PCB) : void
        +onFileOperation(p : PCB, opName : String, filename : String) : void
        +onExecutionError(p : PCB, msg : String) : void
        +onAllFinished() : void
    }

    class ProcessRow {
        +pid : int
        +name : String
        +state : String
        +priority : int
        +burst : long
        +waiting : long
        +pc : int
        +cpuId : int
    }

    class MemoryRow {
        +address : int
        +value : String
        +owner : String
    }

    class DiskRow {
        +address : int
        +zone : String
        +value : String
    }

    SimuladorApp *-- SimuladorController : "«posee»"
    SimuladorController *-- "0..*" ProcessRow : "modelo de cola"
    SimuladorController *-- "0..*" MemoryRow : "modelo de RAM"
    SimuladorController *-- "0..*" DiskRow : "modelo de disco"
}

' ================================================================
' PAQUETE KERNEL
