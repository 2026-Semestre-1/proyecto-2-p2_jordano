package "simuladorminipc.kernel" #BBDEFB {

    interface KernelEventListener <<interface>> {
        +onTickCompleted(tick : long) : void
        +onProcessStateChanged(p : PCB, prev : ProcessState, curr : ProcessState) : void
        +onScreenOutput(p : PCB, text : String) : void
        +onKeyboardInputRequired(p : PCB) : void
        +onFileOperation(p : PCB, opName : String, filename : String) : void
        +onExecutionError(p : PCB, msg : String) : void
        +onAllFinished() : void
    }

    class Kernel {
        -clock : SystemClock
        -processManager : ProcessManager
        -queueManager : QueueManager
        -stateManager : StateManager
        -scheduler : SchedulingPolicyManager
        -dispatcher : Dispatcher
        -cpu : CPU
        -ioManager : IOManager
        -interruptManager : InterruptManager
        -memoryManager : MemoryManager
        -vmm : VirtualMemoryManager
        -swapManager : SwapManager
        -disk : Disk
        -statisticsManager : StatisticsManager
        -listeners : List<KernelEventListener>
        -booted : boolean
        -halted : boolean
        -waitingForKeyboard : PCB
        --
        +boot() : void
        +executeTick() : void
        +loadProcess(p : PCB) : void
        +provideKeyboardInput(value : int) : void
        +reset() : void
        +addListener(l : KernelEventListener) : void
        +setPolicy(p : Policy) : void
        +setQuantum(q : int) : void
        -scheduleAndDispatch(tick : long) : void
        -handleCycleEvent(ev : CycleEvent, process : PCB, tick : long) : void
        -handleQuantumExpiry(p : PCB, tick : long) : void
        -allFinished() : boolean
        -fireTickCompleted(tick : long) : void
        -fireProcessStateChanged(p : PCB, prev : ProcessState, curr : ProcessState) : void
        -fireScreenOutput(p : PCB, text : String) : void
        -fireKeyboardInputRequired(p : PCB) : void
        -fireFileOperation(p : PCB, op : String, file : String) : void
        -fireExecutionError(p : PCB, msg : String) : void
        -fireAllFinished() : void
    }

    Kernel --> "0..*" KernelEventListener : "«notifica»"
}

' ================================================================
' PAQUETE ASSEMBLER
