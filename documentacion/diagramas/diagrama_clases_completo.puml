package "simuladorminipc.assembler" #E8F5E9 {

    class Assembler <<utility>> {
        -{static} CONFIG : AssemblerConfig
        -{static} REGISTER_PATTERN : Pattern
        -{static} INT_PATTERN : Pattern
        --
        +{static} parse(file : File) : List<Instruction>
        -{static} parseLine(line : String, lineNum : int) : Instruction
        -{static} splitOperands(raw : String, expected : int, lineNum : int) : String[]
        -{static} requireRegister(token : String, lineNum : int) : String
        -{static} requireInt(token : String, lineNum : int) : int
        -{static} parseAhValue(token : String, lineNum : int) : int
    }

    class Instruction {
        -type : InstructionType
        -operand1 : String
        -operand2 : String
        -stringLiteral : String
        -original : String
        -weight : int
        -lineNumber : int
        --
        +getType() : InstructionType
        +getOperand1() : String
        +getOperand2() : String
        +getStringLiteral() : String
        +getOriginal() : String
        +getWeight() : int
        +getLineNumber() : int
    }

    enum InstructionType {
        LOAD
        STORE
        MOV
        ADD
        SUB
        INC
        DEC
        SWAP
        INT_20H
        INT_10H
        INT_09H
        INT_21H
        JMP
        CMP
        JE
        JNE
        PARAM
        PUSH
        POP
        --
        -weight : int
        +getWeight() : int
    }

    Assembler ..> Instruction : "«crea»"
    Instruction --> InstructionType : "tipada por"
}

